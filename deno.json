{
  "name": "@sabakernel/arrow-header",
  "version": "0.1.2",
  "exports": "./mod.ts",
  "imports": {
    "@deno/dnt": "jsr:@deno/dnt@^0.42.3",
    "@std/assert": "jsr:@std/assert@^1.0.19",
    "~/": "./src/"
  },
  "tasks": {
    "dev": "deno run --watch main.ts",
    "build": "deno run -A build_npm.ts",
    "test": "deno test -A",
    "lint": "deno lint",
    "fmt": "deno fmt"
  },
  "include": [
    "src",
    "test",
    "deno.json",
    "build_npm.ts",
    "mod.ts"
  ],
  "exclude": ["node_modules"],
  "fmt": {
    "useTabs": false,
    "lineWidth": 100,
    "indentWidth": 2,
    "singleQuote": true
  }
}
